# Copia este fichero a `.streamlit/secrets.toml` y pega tu API key.
# `.streamlit/secrets.toml` está en .gitignore — nunca se subirá al repo.
#
# Si prefieres no usar Streamlit secrets, la app caerá automáticamente a la
# `ANTHROPIC_API_KEY` definida en `.env` (cargada por pydantic-settings).

ANTHROPIC_API_KEY = "sk-ant-..."
